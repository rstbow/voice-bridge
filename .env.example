# Junior Construction GHL -> AccuLynx bridge — env config
# Copy to .env and fill in. Never commit .env.

NODE_ENV=development
PORT=3010
LOG_LEVEL=info

# Default client served by this service.
# Drives credential/config lookups via getCredentials(clientId, ...).
DEFAULT_CLIENT_ID=junior-construction

# Webhook auth — shared secret GHL Workflow includes as header
# X-Bridge-Token. Random per env. Set the same value in the GHL workflow
# webhook header config.
BRIDGE_WEBHOOK_TOKEN=replace-me-with-uuid

# SQL connection (Azure SQL — vs-ims server, vs-ims-staging DB per Chip).
# Defaults are baked into lib/db.js — only override here if needed.
# SQL_SERVER=vs-ims.database.windows.net
# SQL_DATABASE=vs-ims-staging
# SQL_USER=alf_bridge_app_user
# SQL_PASSWORD=...   (left unset locally; auto-resolved via getCredentials.
#                     In Azure App Service, set this to the value from
#                     secrets/junior-construction-bridge-sql.md)

# Junior Construction's Brand_UID — real value, sourced from
# tbl_PPA_L_Brand by Randy 2026-04-29.
# IMPORTANT: Brand_UIDs come from the SKU Compass brand onboarding
# process (Nator-owned). Never generate one ad-hoc.
JUNIOR_CONSTRUCTION_BRAND_UID=8e900fb5-f72b-4293-910b-4fc0539475c4

# Worker schedule
WORKER_CRON=*/2 * * * *
WORKER_BATCH_SIZE=20
WORKER_MAX_RETRIES=5
